{
  "metadata": {
    "name": "app-ciudadano",
    "slug": "app-ciudadano",
    "scheme": "appciudadano",
    "androidPackage": "com.sg.ciudadano",
    "iosBundleIdentifier": "com.sg.ciudadano",
    "version": "1.0.0",
    "orientation": "portrait"
  },
  "branding": {
    "appName": "app-ciudadano",
    "logo": {
      "kind": "none"
    }
  },
  "theme": {
    "colorMode": "system",
    "light": {
      "primary": "#2D2B27",
      "secondary": "#81673B",
      "background": "#D9D9D9",
      "surface": "#FFFFFF",
      "text": "#2D2B27",
      "textMuted": "#81673B",
      "border": "#81673B",
      "buttonText": "#FFFFFF",
      "statusBarStyle": "dark"
    },
    "dark": {
      "primary": "#D87706",
      "secondary": "#81673B",
      "background": "#2D2B27",
      "surface": "#81673B",
      "text": "#D9D9D9",
      "textMuted": "#D9D9D9",
      "border": "#81673B",
      "buttonText": "#FFFFFF",
      "statusBarStyle": "light"
    }
  },
  "navigationTabs": {
    "ios": {
      "tintColor": "#81673B"
    },
    "android": {
      "activeBackground": "#81673B",
      "activeForeground": "#FFFFFF",
      "inactiveBackground": "#FFFFFF",
      "inactiveForeground": "#64625F"
    },
    "web": {
      "activeBackground": "#81673B",
      "activeForeground": "#FFFFFF",
      "inactiveBackground": "#FFFFFF",
      "inactiveForeground": "#64625F"
    }
  },
  "assets": {
    "appIcon": "./assets/images/icon.png",
    "iosIcon": "./assets/expo.icon",
    "webFavicon": "./assets/images/favicon.png",
    "androidAdaptiveIcon": {
      "backgroundColor": "#D9D9D9",
      "foregroundImage": "./assets/images/android-icon-foreground.png",
      "backgroundImage": "./assets/images/android-icon-background.png",
      "monochromeImage": "./assets/images/android-icon-monochrome.png"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "darkImage": "./assets/images/splash-icon.png",
      "backgroundColor": "#D9D9D9",
      "darkBackgroundColor": "#2D2B27",
      "imageWidth": 92
    }
  },
  "apiDefaults": {
    "defaultHeaders": {
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "modules": {
    "alerts": {
      "shellBackground": "#C5B099",
      "panelBackground": "#C5B099",
      "panelText": "#60595D",
      "progressActive": "#FFFFFF",
      "progressInactive": "#DACEC0",
      "circleStart": "#92272C",
      "circleEnd": "#BD6236",
      "circleGlow": "#CDB19C",
      "actionBackground": "#2D2B27",
      "actionText": "#FFFFFF",
      "tileIcon": "#79142A",
      "tileText": "#60595D",
      "severity": {
        "preventive": "#F7C933",
        "emergency": "#E01D24",
        "informative": "#188BD1"
      },
      "switchActive": "#63B32E",
      "switchInactive": "#E3E1DE",
      "map": {
        "primary": "#6C99F0",
        "secondary": "#8CB0F6",
        "marker": "#E01D24"
      }
    }
  }
}
